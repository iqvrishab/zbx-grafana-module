{
  "manifest_version": 2.0,
  "id": "grafana-dashboards",
  "name": "Grafana Dashboards",
  "version": "1.1.1",
  "author": "Vrishab Rayu",
  "namespace": "GrafanaDashboards",
  "description": "Embed Grafana dashboards directly inside Zabbix.",
  "actions": {
    "grafana.list": {
      "class": "ActionGrafanaList",
      "layout": "layout.htmlpage"
    },
    "grafana.edit": {
      "class": "ActionGrafanaEdit",
      "layout": "layout.htmlpage"
    },
    "grafana.delete": {
      "class": "ActionGrafanaDelete",
      "layout": "layout.htmlpage"
    },
    "grafana.view": {
      "class": "ActionGrafanaView",
      "layout": "layout.htmlpage"
    }
  }
}
